{
  "name": "bytecode-afiliados",
  "version": "1.0.0",
  "description": "Plataforma de Ecommerce para integração com lojas que permitem afiliados",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "dev:debug": "nodemon --exec node --inspect=0.0.0.0:9229 -r ts-node/register src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/database.ts",
    "migration:gen": "node scripts/migration.js",
    "migration:run": "npm run typeorm -- migration:run -d src/config/database.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/database.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/config/database.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeanBonatto/bytecode-afiliados.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/JeanBonatto/bytecode-afiliados/issues"
  },
  "homepage": "https://github.com/JeanBonatto/bytecode-afiliados#readme",
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@nestjs/mapped-types": "^2.1.1",
    "axios": "^1.16.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0"
  }
}
